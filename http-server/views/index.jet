<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
		<title>gRPC Demo</title>

		<!-- Tailwind and Alpine -->
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
		<script src="https://cdn.tailwindcss.com"></script>
		<script src="//unpkg.com/alpinejs" defer></script>
		<script src="https://unpkg.com/axios@1.13.2/dist/axios.min.js"></script>
	</head>

	<body class="bg-gray-100 min-h-screen flex flex-col">

		<!-- Header -->
		<header class="bg-blue-600 text-white p-4 shadow">
			<h1 class="text-xl font-semibold">gRPC Cross-Language Communication Demo</h1>
		</header>

		<!-- Main Content -->
		<main class="flex-1 p-6" x-data="app">
			<div class="max-w-4xl mx-auto bg-white p-6 rounded-lg shadow">
				<!-- Title -->
				<div class="flex justify-between items-center mb-4">
					<h2 class="text-lg font-bold">List of Users</h2>

					<!-- New User Button -->
					<button 
						@click="openCreateModal"
						class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">
						New User
					</button>
				</div>

				<!-- Table -->
				<div class="overflow-x-auto">
					<table class="w-full border border-gray-200 rounded">
						<thead class="bg-gray-50">
							<tr>
								<th class="text-left p-3 border-b">ID</th>
								<th class="text-left p-3 border-b">Name</th>
								<th class="text-left p-3 border-b">Age</th>
								<th class="text-left p-3 border-b">Location</th>
								<th class="text-left p-3 border-b">Email</th>
								<th class="text-left p-3 border-b">Actions</th>
							</tr>
						</thead>
						<tbody>
							<template x-for="user in users">
								<tr class="hover:bg-gray-50">
									<td class="p-3 border-b" x-text="user.id"></td>
									<td class="p-3 border-b" x-text="user.name"></td>
									<td class="p-3 border-b" x-text="user.age"></td>
									<td class="p-3 border-b" x-text="user.location"></td>
									<td class="p-3 border-b" x-text="user.email"></td>

									<!-- Actions -->
									<td class="p-3 border-b">
										<div class="flex gap-2">
											<!-- Edit Button -->
											<button class="text-blue-600 hover:text-blue-800 p-1 rounded hover:bg-gray-100" title="Edit" @click="openEditModal( user.id )">
											  <!-- Pencil Icon -->
												<svg xmlns="http://www.w3.org/2000/svg" 
													class="w-5 h-5" fill="none" 
													viewBox="0 0 24 24" stroke="currentColor">
													<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536M9 13l6.768-6.768a2.5 2.5 0 113.536 3.536L12.5 16.5H9v-3.5z" />
												</svg>
											</button>

											<!-- Delete Button -->
											<button class="text-red-600 hover:text-red-800 p-1 rounded hover:bg-gray-100" title="Delete" @click="if(confirm('Delete this user?')) deleteUser( user.id )">
												<!-- Trash Icon -->
												<svg xmlns="http://www.w3.org/2000/svg" 
													class="w-5 h-5" fill="none" 
													viewBox="0 0 24 24" stroke="currentColor">
													<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 7h12M9 7v10m6-10v10M10 4h4a1 1 0 011 1v1H9V5a1 1 0 011-1z" />
												</svg>
											</button>
										</div>
									</td>
								</tr>
							</template>
						</tbody>
					</table>
				</div>

				<!-- Loading State -->
				<div x-show="loading" class="mt-4 text-blue-600 text-sm">Loading data from gRPC service...</div>
			</div>

			<!-- Overlay -->
			<div x-show="showCreateModal" class="fixed inset-0 z-50 flex items-center justify-center">
				<!-- Backdrop -->
				<div class="absolute inset-0 bg-black/40"></div>
				
				<!-- Modal -->
				<div class="relative w-full max-w-md bg-white rounded-xl shadow-lg border border-gray-200">
					<!-- Header -->
					<div class="flex items-center justify-between px-6 py-4 border-b">
							<h2 class="text-gray-800 text-lg font-semibold">New User</h2>
							<button @click="closeCreateModal" class="text-gray-400 hover:text-gray-600 text-xl leading-none">&times;</button>
					</div>

					<form>
					<div class="p-6 space-y-5">
							<!-- Name -->
							<div class="flex items-center gap-4">
								<!-- Label -->
								<label class="w-32 text-sm text-gray-700">Name</label>
							
								<!-- Input Group -->
								<div class="flex flex-1">
									<!-- Left addon -->
									<span class="inline-flex items-center px-3 text-sm text-gray-600 bg-gray-100 border border-gray-300 rounded-l-lg">
										<i class="fa-solid fa-user"></i>
									</span>

									<!-- Input -->
									<input x-ref="create_focus" x-model="newUserForm.name" type="text" placeholder="Fullname" class="w-full border-t border-b border-r border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 rounded-r-lg">
								</div>
							</div>

							<!-- Email -->
							<div class="flex items-center gap-4">
								<label class="w-32 text-sm text-gray-700">Email</label>
								<div class="flex flex-1">
									<!-- Prefix / group text -->
									<span class="inline-flex items-center px-3 text-sm text-gray-600 bg-gray-100 border border-gray-300 rounded-l-lg"><i class="fa-solid fa-envelope"></i></span>

									<!-- Input -->
									<input type="text" x-model="newUserForm.email" placeholder="Email" class="w-full border-t border-b border-r border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 rounded-r-lg">
								</div>
							</div>

							<!-- Age -->
							<div class="flex items-center gap-4">
								<!-- Label -->
								<label class="w-32 text-sm text-gray-700">Age</label>
							
								<!-- Input Group -->
								<div class="flex flex-1">
									<!-- Left addon -->
									<span class="inline-flex items-center px-3 text-sm text-gray-600 bg-gray-100 border border-gray-300 rounded-l-lg">
										<i class="fa-solid fa-clock"></i>
									</span>

									<!-- Input -->
									<input type="number"  x-model="newUserForm.age" min="1" max="100" placeholder="Age" class="w-full border-t border-b border-r border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 rounded-r-lg">
								</div>
							</div>

							<!-- Location -->
							<div class="flex items-center gap-4">
								<!-- Label -->
								<label class="w-32 text-sm text-gray-700">Location</label>
							
								<!-- Input Group -->
								<div class="flex flex-1">
									<!-- Left addon -->
									<span class="inline-flex items-center px-3 text-sm text-gray-600 bg-gray-100 border border-gray-300 rounded-l-lg">
										<i class="fa-solid fa-location-dot"></i>
									</span>

									<!-- Input -->
									<input type="text"  x-model="newUserForm.location" placeholder="City / Country" class="w-full border-t border-b border-r border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 rounded-r-lg">
								</div>
							</div>
					</div>
					</form>

					<!-- Footer -->
					<div class="flex justify-end gap-3 px-6 py-4 border-t bg-gray-50 rounded-b-xl">
						<button @click="closeCreateModal" class="px-4 py-2 text-sm border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-100">Cancel</button>
						<button @click="newUser" class="px-4 py-2 text-sm bg-blue-600 text-white rounded-lg hover:bg-blue-700">Save</button>
					</div>
				</div>
			</div>

			<div x-show="showEditModal" class="fixed inset-0 z-50 flex items-center justify-center">
				<!-- Backdrop -->
				<div class="absolute inset-0 bg-black/40"></div>
				
				<!-- Modal -->
				<div class="relative w-full max-w-md bg-white rounded-xl shadow-lg border border-gray-200">
					<!-- Header -->
					<div class="flex items-center justify-between px-6 py-4 border-b">
							<h2 class="text-gray-800 text-lg font-semibold">Edit User</h2>
							<button @click="closeEditModal" class="text-gray-400 hover:text-gray-600 text-xl leading-none">&times;</button>
					</div>

					<form>
						<input x-model="editUserForm.id" type="hidden" name="id">
					<div class="p-6 space-y-5">
							<!-- Name -->
							<div class="flex items-center gap-4">
								<!-- Label -->
								<label class="w-32 text-sm text-gray-700">Name</label>
							
								<!-- Input Group -->
								<div class="flex flex-1">
									<!-- Left addon -->
									<span class="inline-flex items-center px-3 text-sm text-gray-600 bg-gray-100 border border-gray-300 rounded-l-lg">
										<i class="fa-solid fa-user"></i>
									</span>

									<!-- Input -->
									<input x-ref="edit_focus" x-model="editUserForm.name" type="text" placeholder="Fullname" class="w-full border-t border-b border-r border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 rounded-r-lg">
								</div>
							</div>

							<!-- Email -->
							<div class="flex items-center gap-4">
								<label class="w-32 text-sm text-gray-700">Email</label>
								<div class="flex flex-1">
									<!-- Prefix / group text -->
									<span class="inline-flex items-center px-3 text-sm text-gray-600 bg-gray-100 border border-gray-300 rounded-l-lg"><i class="fa-solid fa-envelope"></i></span>

									<!-- Input -->
									<input type="text" x-model="editUserForm.email" placeholder="Email" class="w-full border-t border-b border-r border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 rounded-r-lg">
								</div>
							</div>

							<!-- Age -->
							<div class="flex items-center gap-4">
								<!-- Label -->
								<label class="w-32 text-sm text-gray-700">Age</label>
							
								<!-- Input Group -->
								<div class="flex flex-1">
									<!-- Left addon -->
									<span class="inline-flex items-center px-3 text-sm text-gray-600 bg-gray-100 border border-gray-300 rounded-l-lg">
										<i class="fa-solid fa-clock"></i>
									</span>

									<!-- Input -->
									<input type="number"  x-model="editUserForm.age" min="1" max="100" placeholder="Age" class="w-full border-t border-b border-r border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 rounded-r-lg">
								</div>
							</div>

							<!-- Location -->
							<div class="flex items-center gap-4">
								<!-- Label -->
								<label class="w-32 text-sm text-gray-700">Location</label>
							
								<!-- Input Group -->
								<div class="flex flex-1">
									<!-- Left addon -->
									<span class="inline-flex items-center px-3 text-sm text-gray-600 bg-gray-100 border border-gray-300 rounded-l-lg">
										<i class="fa-solid fa-location-dot"></i>
									</span>

									<!-- Input -->
									<input type="text"  x-model="editUserForm.location" placeholder="City / Country" class="w-full border-t border-b border-r border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 rounded-r-lg">
								</div>
							</div>
					</div>
					</form>

					<!-- Footer -->
					<div class="flex justify-end gap-3 px-6 py-4 border-t bg-gray-50 rounded-b-xl">
						<button @click="closeEditModal" class="px-4 py-2 text-sm border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-100">Cancel</button>
						<button @click="editUser" class="px-4 py-2 text-sm bg-blue-600 text-white rounded-lg hover:bg-blue-700">Save</button>
					</div>
				</div>
			</div>
		</main>

		<!-- Footer -->
		<footer class="bg-gray-800 text-white text-center p-4 text-sm">Copyright © 2026 <a href="https://elmyrockers.github.io">elmyrockers.github.io</a></footer>


		<script>
			var v = null;
			document.addEventListener( 'alpine:init',()=>{
				Alpine.data( 'app',()=>({
					users: {
						'1': {id:'1', name:"Helmi", email: "helmi@xeno.com.my", age: "35", location: "Kuala Lumpur"},
						'2': {id:'2', name:"Khairul", email: "khairul@gmail.com", age: "29", location: "Alor Setar"},
					},
					loading: false,
					showCreateModal: false,
					showEditModal: false,
					newUserForm: {
						name: "",
						email: "",
						age: "",
						location: "",
					},
					editUserForm: {
						id: "",
						name: "",
						email: "",
						age: "",
						location: "",
					},
					reloadUsers(){

					},
					openCreateModal(){
						this.showCreateModal = true;
						this.$nextTick(() => {
							this.$refs.create_focus.focus();
						})
					},
					openEditModal( id ){
						this.editUserForm = this.users[id];
						// console.log( 'User: ', this.users[id] );

						this.showEditModal = true;
						this.$nextTick(() => {
							this.$refs.edit_focus.focus();
						})
					},
					closeCreateModal(){ this.showCreateModal = false },
					closeEditModal(){ this.showEditModal = false },
					newUser(){
						console.log( this.newUserForm );
					},
					editUser(){
						console.log( this.editUserForm );
					},
					deleteUser( id ){
						console.log( `User ID: ${id}` );
						alert( 'Deleted!' );
					}
				}));
			});
		</script>

	</body>
</html>