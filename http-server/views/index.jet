<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
		<title>gRPC Demo</title>

		<!-- Tailwind and Alpine -->
		<script src="https://cdn.tailwindcss.com"></script>
		<script src="https://cdn.jsdelivr.net/npm/alpinejs" defer></script>
	</head>

	<body class="bg-gray-100 min-h-screen flex flex-col">

		<!-- Header -->
		<header class="bg-blue-600 text-white p-4 shadow">
			<h1 class="text-xl font-semibold">gRPC Cross-Language Communication Demo</h1>
		</header>

		<!-- Main Content -->
		<main class="flex-1 p-6" x-data="{ loading: false }">
			<div class="max-w-4xl mx-auto bg-white p-6 rounded-lg shadow">
				<!-- Title -->
				<div class="flex justify-between items-center mb-4">
					<h2 class="text-lg font-bold">List of Users</h2>

					<!-- Example Button -->
					<button 
						@click="loading = true; setTimeout(() => loading = false, 1000)"
						class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">
						New User
					</button>
				</div>

				<!-- Table -->
				<div class="overflow-x-auto">
					<table class="w-full border border-gray-200 rounded">
						<thead class="bg-gray-50">
							<tr>
								<th class="text-left p-3 border-b">ID</th>
								<th class="text-left p-3 border-b">Name</th>
								<th class="text-left p-3 border-b">Age</th>
								<th class="text-left p-3 border-b">Location</th>
								<th class="text-left p-3 border-b">Email</th>
								<th class="text-left p-3 border-b">Actions</th>
							</tr>
						</thead>
						<tbody>
							<tr class="hover:bg-gray-50">
								<td class="p-3 border-b">1</td>
								<td class="p-3 border-b">Helmi Aziz</td>
								<td class="p-3 border-b">30</td>
								<td class="p-3 border-b">Kuala Lumpur</td>
								<td class="p-3 border-b">elmyrockers@email.com</td>

								<!-- Actions -->
								<td class="p-3 border-b">
									<div class="flex gap-2">
										<!-- Edit Button -->
										<button class="text-blue-600 hover:text-blue-800 p-1 rounded hover:bg-gray-100" title="Edit" @click="alert('Edit user 1')">
										  <!-- Pencil Icon -->
											<svg xmlns="http://www.w3.org/2000/svg" 
												class="w-5 h-5" fill="none" 
												viewBox="0 0 24 24" stroke="currentColor">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536M9 13l6.768-6.768a2.5 2.5 0 113.536 3.536L12.5 16.5H9v-3.5z" />
											</svg>
										</button>

										<!-- Delete Button -->
										<button class="text-red-600 hover:text-red-800 p-1 rounded hover:bg-gray-100" title="Delete" @click="if(confirm('Delete this user?')) alert('Deleted!')">
											<!-- Trash Icon -->
											<svg xmlns="http://www.w3.org/2000/svg" 
												class="w-5 h-5" fill="none" 
												viewBox="0 0 24 24" stroke="currentColor">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 7h12M9 7v10m6-10v10M10 4h4a1 1 0 011 1v1H9V5a1 1 0 011-1z" />
											</svg>
										</button>
									</div>
								</td>
							</tr>
						</tbody>
					</table>
				</div>

				<!-- Loading State -->
				<div x-show="loading" class="mt-4 text-blue-600 text-sm">
					Loading data from gRPC service...
				</div>
			</div>
		</main>

		<!-- Footer -->
		<footer class="bg-gray-800 text-white text-center p-4 text-sm">Copyright © 2026 <a href="https://elmyrockers.github.io">elmyrockers.github.io</a></footer>

	</body>
</html>